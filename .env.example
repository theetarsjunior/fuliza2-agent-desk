# Safaricom Daraja Sandbox Credentials
DARAJA_CONSUMER_KEY=your_consumer_key_here
DARAJA_CONSUMER_SECRET=your_consumer_secret_here
DARAJA_SHORTCODE=your_shortcode_here
DARAJA_PASSKEY=your_passkey_here
DARAJA_SANDBOX_URL=https://sandbox.safaricom.co.ke

# PayHero API (optional, for real M-Pesa STK Push)
# Preferred: token copied from PayHero dashboard (Authorization: Basic <token>)
PAYHERO_AUTH_TOKEN=your_payhero_auth_token
PAYHERO_BASE_URL=https://backend.payhero.co.ke/api/v2

# Required for STK push
PAYHERO_CHANNEL_ID=123

# Optional: PayHero will POST results here (must be publicly reachable)
PAYHERO_CALLBACK_URL=https://your-domain.com/api/payhero/callback

# Alternative (if your account uses key/secret basic auth)
PAYHERO_API_KEY=your_payhero_api_key
PAYHERO_API_SECRET=your_payhero_api_secret

# Backend server port
PORT=4000
